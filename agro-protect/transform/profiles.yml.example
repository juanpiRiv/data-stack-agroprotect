# BigQuery: dbt `schema` is the BigQuery dataset name (dbt-bigquery 1.9+).
# Default `analytics` matches agro-protect/.env.example if BIGQUERY_DATASET_ID is unset (empty CI secret would otherwise error: Must specify schema).
agroprotect:

  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID', 'analytics') }}"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

    ci:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID', 'analytics') }}_ci"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

    prod:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID', 'analytics') }}"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

  target: dev
