# BigQuery: dbt `schema` is the BigQuery dataset name (dbt-bigquery 1.9+).
agroprotect:

  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID') }}"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

    ci:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID') }}_ci"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

    prod:
      type: bigquery
      method: service-account
      project: "{{ env_var('BIGQUERY_PROJECT_ID') }}"
      schema: "{{ env_var('BIGQUERY_DATASET_ID') }}"
      location: "{{ env_var('BIGQUERY_LOCATION') }}"
      keyfile: "{{ env_var('DBT_GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4

  target: dev
