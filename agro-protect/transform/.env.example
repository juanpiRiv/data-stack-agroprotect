# dbt reads variables from the `agro-protect/` root `.env`.
# From here: cp ../.env.example ../.env then, under transform/:
#   set -a && source ../.env && set +a
#
# Minimum required: BIGQUERY_PROJECT_ID, BIGQUERY_DATASET_ID, BIGQUERY_LOCATION,
# DBT_GOOGLE_APPLICATION_CREDENTIALS (path to the dbt service account JSON).
#
# Slim CI (GitHub Actions only): secret DBT_MANIFEST_GCS_URI = gs://bucket/path/manifest.json
# (the dbt SA needs read/write on that object; see agro-protect root README).
