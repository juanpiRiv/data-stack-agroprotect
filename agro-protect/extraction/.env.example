# Extraction (Meltano) — use `agro-protect/.env` or copy this file to `extraction/.env`.
#
# REQUIRED before `meltano run … target-bigquery` (meltano.yml reads these vars):
#   set -a && source ../.env && set +a
#
# Option A: from `agro-protect/` with `.env` at package root.
# Option B: cp .env.example .env and fill in values.

# Required by target-bigquery in meltano.yml
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_LOCATION=US
MELTANO_GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/meltano-sa.json

# Compatibility (dbt / docs); can match the values above
TARGET_BIGQUERY_PROJECT=${BIGQUERY_PROJECT_ID}
TARGET_BIGQUERY_LOCATION=${BIGQUERY_LOCATION}
TARGET_BIGQUERY_CREDENTIALS_PATH=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

GOOGLE_APPLICATION_CREDENTIALS=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# Meltano state: locally you can OMIT this line (state under .meltano/).
# If set (gs://…), run the project `meltano` from `.venv` with meltano[gcs],
# not `uv tool meltano` (missing google-cloud-storage → ModuleNotFoundError: google).
# Use a real bucket with billing enabled; placeholder buckets → 403.
# MELTANO_STATE_BACKEND_URI=gs://your-project-meltano-state/meltano/state

# tap-agro: disable the tap’s alternate weather provider (this repo: NASA POWER only via meltano.yml + select).
TAP_AGRO_USE_OPEN_METEO=false

# Daily prod: meltano config set tap-agro days_back 1 (see README).

# TAP_AGRO_LOCATION_CATALOG_PATH=/absolute/path/locations.csv
