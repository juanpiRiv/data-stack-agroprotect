# Extracción (Meltano) — usá `agro-protect/.env` o copiá este archivo a `extraction/.env`.
#
# OBLIGATORIO antes de `meltano run … target-bigquery` (meltano.yml lee estas vars):
#   set -a && source ../.env && set +a
#
# Opción A: desde `agro-protect/` con `.env` en la raíz del paquete.
# Opción B: cp .env.example .env y completá.

# Requerido por target-bigquery en meltano.yml
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_LOCATION=US
MELTANO_GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/meltano-sa.json

# Compatibilidad (dbt / docs); puede igualar a lo de arriba
TARGET_BIGQUERY_PROJECT=${BIGQUERY_PROJECT_ID}
TARGET_BIGQUERY_LOCATION=${BIGQUERY_LOCATION}
TARGET_BIGQUERY_CREDENTIALS_PATH=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

GOOGLE_APPLICATION_CREDENTIALS=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# Estado Meltano: en local podés OMITIR esta línea (state en .meltano/).
# Si la definís (gs://…), el `meltano` que corrés debe ser el del proyecto (.venv) con meltano[gcs],
# no `uv tool meltano` (sin google-cloud-storage → ModuleNotFoundError: google).
# Usá un bucket REAL con facturación activa; "tu-bucket" del template → 403.
# MELTANO_STATE_BACKEND_URI=gs://tu-proyecto-meltano-state/meltano/state

# tap-agro: desactiva el proveedor de clima alternativo del tap (este repo solo NASA POWER vía meltano.yml + select).
TAP_AGRO_USE_OPEN_METEO=false

# Diario prod: meltano config set tap-agro days_back 1 (ver README).

# TAP_AGRO_LOCATION_CATALOG_PATH=/ruta/absoluta/locations.csv
