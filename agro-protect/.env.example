# Before `cd extraction && meltano run …`: `set -a && source .env && set +a`
# (meltano.yml uses BIGQUERY_* and MELTANO_GOOGLE_APPLICATION_CREDENTIALS for target-bigquery).

# BigQuery (dbt + Meltano)
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=analytics
BIGQUERY_LOCATION=US
# Separate service accounts: dbt for models, Meltano for extraction/state.
DBT_GOOGLE_APPLICATION_CREDENTIALS=/Users/your_user/Downloads/dbt.json
MELTANO_GOOGLE_APPLICATION_CREDENTIALS=/Users/your_user/Downloads/meltano.json
GOOGLE_APPLICATION_CREDENTIALS=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# Optional locally (without this, state lives under extraction/.meltano/). CI: use a real secret.
# MELTANO_STATE_BACKEND_URI=gs://your-bucket-with-billing-enabled/meltano/state

# Meltano target-bigquery (z3z1ma)
TARGET_BIGQUERY_PROJECT=${BIGQUERY_PROJECT_ID}
TARGET_BIGQUERY_LOCATION=${BIGQUERY_LOCATION}
TARGET_BIGQUERY_CREDENTIALS_PATH=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# dbt sandbox user (used to name dev datasets)
DBT_USER=local

# Slim CI: GitHub secret DBT_MANIFEST_GCS_URI only (gs://…/manifest.json). Locally skip unless you copy manifest manually to prod-artifacts/.

# tap-agro: SDK enables another weather provider by default; this project uses NASA POWER only.
# Keep this line (or equivalent in the environment) before `meltano run`.
TAP_AGRO_USE_OPEN_METEO=false

# Daily prod ingest: `meltano --environment=prod config set tap-agro days_back 1` (see extraction/README.md).

# tap-agro: optional absolute path to catalog (default in meltano.yml: extraction/data/locations.csv)
# TAP_AGRO_LOCATION_CATALOG_PATH=/absolute/path/locations.csv

# --- Export BigQuery → GCS (frontend / JSON in bucket) — see scripts/README.md ---
# SA key for export only (or reuse MELTANO_* if it has BQ read + bucket write).
# EXPORT_GOOGLE_APPLICATION_CREDENTIALS=/path/bq-export-to-gcs.json
# export GOOGLE_APPLICATION_CREDENTIALS="${EXPORT_GOOGLE_APPLICATION_CREDENTIALS}"
# EXPORT_GCS_BUCKET_NAME=your-exports-bucket
# EXPORT_GCS_PREFIX=prod/exports
# Multiple tables: JSON {"blob_key":"dataset.table", ...} → gs://.../blob_key.json
# Trial (GitHub secret same one line): {"locations":"analytics.stg_agro_locations","weather":"analytics.stg_agro_clima_diario_nasa_power"}
# If tables live in dbt dataset stg: {"locations":"stg.stg_agro_locations","weather":"stg.stg_agro_clima_diario_nasa_power"}
# EXPORT_TABLE_MAP={"locations":"analytics.stg_agro_locations"}
# Single table:
# EXPORT_BQ_TABLE_REF=analytics.stg_agro_locations
# EXPORT_GCS_BLOB_NAME=locations

# Extraction-only template under extraction/: extraction/.env.example
