# Antes de `cd extraction && meltano run …`: `set -a && source .env && set +a`
# (meltano.yml usa BIGQUERY_* y MELTANO_GOOGLE_APPLICATION_CREDENTIALS para target-bigquery).

# BigQuery (dbt + Meltano)
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET_ID=analytics
BIGQUERY_LOCATION=US
# Separate service accounts: dbt for models, Meltano for extraction/state.
DBT_GOOGLE_APPLICATION_CREDENTIALS=/Users/nombre_usuario/Downloads/dbt.json
MELTANO_GOOGLE_APPLICATION_CREDENTIALS=/Users/nombre_usuario/Downloads/meltano.json
GOOGLE_APPLICATION_CREDENTIALS=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# Opcional en local (sin esto, el state vive en extraction/.meltano/). CI: secret real.
# MELTANO_STATE_BACKEND_URI=gs://tu-bucket-con-facturacion-activa/meltano/state

# Meltano target-bigquery (z3z1ma)
TARGET_BIGQUERY_PROJECT=${BIGQUERY_PROJECT_ID}
TARGET_BIGQUERY_LOCATION=${BIGQUERY_LOCATION}
TARGET_BIGQUERY_CREDENTIALS_PATH=${MELTANO_GOOGLE_APPLICATION_CREDENTIALS}

# dbt sandbox user (used to name dev datasets)
DBT_USER=local

# Slim CI: solo GitHub Secret DBT_MANIFEST_GCS_URI (gs://…/manifest.json). En local no hace falta salvo que copies el manifest a mano a prod-artifacts/.

# tap-agro: opcional si usás ruta absoluta al catálogo (por defecto meltano.yml usa extraction/data/locations.csv)
# TAP_AGRO_LOCATION_CATALOG_PATH=/ruta/absoluta/locations.csv

# Extracción solo desde carpeta extraction/ (plantilla duplicada mínima): extraction/.env.example
